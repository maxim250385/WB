# ─── Telegram User (Telethon — чтение канала) ─────────────
TG_PHONE=            # твой номер телефона: +7XXXXXXXXXX (нужен при первом запуске)

# ─── Telegram Bot (уведомления) ───────────────────────────
TG_BOT_TOKEN=        # токен от @BotFather
TG_NOTIFY_CHAT_ID=   # твой Telegram user ID (узнать: написать @userinfobot)

# ─── Прокси ───────────────────────────────────────────────
PROXY_USER=          # логин прокси
PROXY_PASS=          # пароль прокси

# ─── Gemini API ──────────────────────────────────────────
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=
GEMINI_KEY_5=
GEMINI_KEY_6=
GEMINI_KEY_7=
GEMINI_KEY_8=
